#!/bin/bash
# =============================================================================
# Qwen3-TTS-Mac-GeneLab ダブルクリック起動ファイル
# =============================================================================
# このファイルを Finder でダブルクリックすると Terminal.app が開いて
# Web UI が自動起動します。

# スクリプト自身のディレクトリに移動
cd "$(dirname "$0")"

# run.sh を実行
exec ./run.sh "$@"
